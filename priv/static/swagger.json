    "/attachments/{id}/download": {
      "get": {
        "tags": [
          "Attachment"
        ],
        "summary": "Download a file attachment",
        "security": [
          {
            "Bearer": []
          }
        ],
        "responses": {
          "404": {
            "description": "Not Found"
          },
          "403": {
            "description": "Forbidden - User cannot access this file"
          },
          "200": {
            "description": "Success - File content"
          }
        },
        "produces": [
          "application/octet-stream"
        ],
        "parameters": [
          {
            "type": "string",
            "required": true,
            "name": "id",
            "in": "path",
            "description": "Attachment UUID"
          }
        ],
        "operationId": "WhisprMessagingWeb.AttachmentController.download",
        "description": "Downloads a file attachment by ID"
      }
    },
    "/attachments/{id}": {
      "get": {
        "tags": [
          "Attachment"
        ],
        "summary": "Get attachment metadata",
        "security": [
          {
            "Bearer": []
          }
        ],
        "responses": {
          "404": {
            "description": "Not Found"
          },
          "200": {
            "schema": {
              "$ref": "#/definitions/AttachmentResponse"
            },
            "description": "Success"
          }
        },
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "type": "string",
            "required": true,
            "name": "id",
            "in": "path",
            "description": "Attachment UUID"
          }
        ],
        "operationId": "WhisprMessagingWeb.AttachmentController.show",
