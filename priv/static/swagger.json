    "/attachments/upload": {
      "post": {
        "tags": [
          "Attachment"
        ],
        "summary": "Upload a file attachment",
        "security": [
          {
            "Bearer": []
          }
        ],
        "responses": {
          "415": {
            "description": "Unsupported media type"
          },
          "413": {
            "description": "File too large (max 50MB)"
          },
          "403": {
            "description": "Forbidden - User cannot upload to this message"
          },
          "400": {
            "description": "Bad Request"
          },
          "201": {
            "schema": {
              "$ref": "#/definitions/AttachmentResponse"
            },
            "description": "Created"
          }
        },
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "type": "file",
            "required": true,
            "name": "file",
