    "/conversations/{id}/members/{user_id}": {
      "delete": {
        "tags": [
          "ConversationMember"
        ],
        "summary": "Remove a member from a conversation",
        "security": [
          {
            "Bearer": []
          }
        ],
        "responses": {
          "404": {
            "description": "Member or Conversation Not Found"
          },
          "403": {
            "description": "Forbidden - User is not an admin or owner of this conversation"
          },
          "204": {
            "description": "No Content - Member removed successfully"
          }
        },
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "type": "string",
            "required": true,
            "name": "id",
            "in": "path",
            "description": "Conversation UUID"
          },
          {
            "type": "string",
            "required": true,
            "name": "user_id",
            "in": "path",
            "description": "UUID of the member to remove"
          }
        ],
        "operationId": "WhisprMessagingWeb.ConversationMemberController.delete",
        "description": "Removes a user from a conversation. Requires admin or owner role."
      }
    },
    "/conversations/{id}/members": {
      "post": {
