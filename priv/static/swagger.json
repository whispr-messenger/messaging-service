            "schema": {
              "$ref": "#/definitions/ConversationMemberResponse"
            },
            "description": "Created"
          }
        },
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "type": "string",
            "required": true,
            "name": "id",
            "in": "path",
            "description": "Conversation UUID"
          },
          {
            "schema": {
              "$ref": "#/definitions/ConversationMemberCreateRequest"
            },
            "required": true,
            "name": "member",
            "in": "body",
            "description": "Member to add"
          }
        ],
        "operationId": "WhisprMessagingWeb.ConversationMemberController.create",
        "description": "Adds a user to an existing conversation. Requires admin or owner role.",
        "consumes": [
          "application/json"
        ]
      }
    },
