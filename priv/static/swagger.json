  "definitions": {
    "MessageShowResponse": {
      "type": "object",
      "title": "Message Show Response",
      "properties": {
        "data": {
          "description": "Message object",
          "$ref": "#/definitions/Message"
        }
      },
      "description": "Response containing a single message without metadata"
    },
    "MessageDeleteResponse": {
      "type": "object",
      "title": "Message Delete Response",
      "properties": {
        "data": {
          "type": "object",
          "properties": {
            "is_deleted": {
              "type": "boolean",
              "description": "Whether the message is deleted"
            },
            "id": {
              "type": "string",
              "description": "Message UUID"
            },
            "deleted_at": {
              "type": "string",
              "description": "Deletion timestamp"
            },
            "delete_for_everyone": {
              "type": "boolean",
              "description": "Whether the message was deleted for everyone"
            }
          },
          "description": "Delete result"
        }
      },
      "description": "Response after deleting a message"
    },
    "MessageUpdateResponse": {
      "type": "object",
      "title": "Message Update Response",
      "properties": {
        "meta": {
          "type": "object",
          "properties": {
            "edited_at": {
              "type": "string",
              "description": "Timestamp of the edit"
            },
            "edited": {
              "type": "boolean",
              "description": "Whether the message was edited"
            }
          },
          "description": "Edit metadata"
        },
        "data": {
          "description": "Updated message object",
          "$ref": "#/definitions/Message"
        }
      },
      "description": "Response after updating a message"
    },
    "MessageUpdateRequest": {
      "type": "object",
      "title": "Message Update Request",
      "properties": {
        "message": {
          "type": "object",
          "properties": {
            "metadata": {
              "type": "object",
              "description": "Additional metadata"
            },
            "content": {
              "type": "string",
              "description": "Message content"
            }
          },
          "description": "Message update parameters"
        }
      },
      "description": "Request body for updating a message"
    },
    "MessageResponse": {
      "type": "object",
      "title": "Message Response",
      "properties": {
        "meta": {
          "type": "object",
          "properties": {
            "conversation_id": {
              "type": "string",
              "description": "Conversation UUID"
            }
          },
          "description": "Response metadata"
        },
        "data": {
          "description": "Message object",
          "$ref": "#/definitions/Message"
        }
      },
      "description": "Response containing a single message"
    },
    "MessageCreateRequest": {
      "type": "object",
      "title": "Message Create Request",
      "properties": {
        "message": {
          "type": "object",
          "required": [
            "content"
          ],
          "properties": {
            "reply_to_id": {
              "type": "string",
              "description": "UUID of message being replied to"
            },
            "metadata": {
              "type": "object",
              "description": "Additional metadata"
            },
            "message_type": {
              "type": "string",
              "description": "Message type"
            },
            "content": {
              "type": "string",
              "description": "Message content"
            }
          },
          "description": "Message parameters"
        }
      },
      "description": "Request body for creating a message"
    },
    "MessagesResponse": {
      "type": "object",
      "title": "Messages Response",
      "properties": {
        "meta": {
          "type": "object",
          "properties": {
            "has_more": {
              "type": "boolean",
              "description": "Whether more messages are available"
            },
            "count": {
              "type": "integer",
              "description": "Total number of messages returned"
            },
            "conversation_id": {
              "type": "string",
              "description": "Conversation UUID"
            }
          },
          "description": "Pagination metadata"
        },
        "data": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Message"
          },
          "description": "List of messages"
        }
      },
      "description": "Response containing a list of messages"
    },
    "ReadinessResponse": {
      "type": "object",
      "title": "Readiness Response",
      "properties": {
        "type": {
          "type": "string",
          "example": "readiness",
          "description": "Type of health check"
        },
        "timestamp": {
          "type": "string",
          "description": "ISO8601 timestamp"
        },
        "status": {
          "type": "string",
          "example": "ready",
          "description": "Readiness status (ready or not_ready)"
        },
        "service": {
          "type": "string",
          "example": "whispr-messaging",
          "description": "Service name"
        },
        "checks": {
          "type": "object",
          "description": "Status of critical dependencies (database: ok/failed/unknown, redis: ok/failed/unknown)"
        }
      },
      "description": "Readiness probe response. Status will be 'ready' when all dependencies are healthy, or 'not_ready' when any dependency fails."
    },
