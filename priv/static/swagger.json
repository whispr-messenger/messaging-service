        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "type": "string",
            "required": true,
            "name": "id",
            "in": "path",
            "description": "Attachment UUID"
          }
        ],
        "operationId": "WhisprMessagingWeb.AttachmentController.delete",
