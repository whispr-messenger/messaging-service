    },
    "/health/detailed": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Detailed health check",
        "responses": {
          "503": {
            "description": "Service Unavailable - when dependencies are unhealthy"
          },
          "200": {
            "schema": {
              "$ref": "#/definitions/HealthResponse"
            },
            "description": "Success"
          }
        },
        "produces": [
          "application/json"
        ],
        "parameters": [],
        "operationId": "WhisprMessagingWeb.HealthController.detailed",
        "description": "Returns detailed health status with comprehensive metrics and diagnostics"
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Comprehensive health check",
        "responses": {
          "503": {
            "description": "Service Unavailable - when dependencies are unhealthy"
          },
          "200": {
            "schema": {
              "$ref": "#/definitions/HealthResponse"
            },
            "description": "Success"
          }
        },
        "produces": [
          "application/json"
        ],
        "parameters": [],
        "operationId": "WhisprMessagingWeb.HealthController.check",
        "description": "Returns the health status of the service and all its dependencies. Supports optional 'type' query parameter: 'live' for liveness probe (lightweight), 'ready' for readiness probe (checks dependencies), or omit for full health check with metrics."
      }
    },
    "/conversations/{id}/messages": {
      "post": {
        "tags": [
          "Message"
